{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://coding-guard.memoryai.dev/schema/v1.json",
  "title": "MemoryAI Coding-Guard Constitution Schema",
  "description": "Schema for rules/constitution.toml — source-of-truth for all platform outputs.",
  "type": "object",
  "required": ["meta", "rules", "gates"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["name", "version", "spec"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "spec": { "type": "string", "const": "constitution/v1" },
        "license": { "type": "string" },
        "homepage": { "type": "string", "format": "uri" },
        "authors": { "type": "array", "items": { "type": "string" } },
        "created": { "type": "string", "format": "date" }
      }
    },
    "anchor": {
      "type": "object",
      "properties": {
        "parent": { "type": "string" },
        "hash": { "type": "string" },
        "immutable": { "type": "boolean" },
        "co_signers_required": { "type": "integer", "minimum": 0 }
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "weight", "severity", "enforce", "short"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 },
          "severity": { "type": "string", "enum": ["block", "warn", "advisory"] },
          "enforce": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["pre-edit", "post-edit", "pre-tool-call", "post-tool-call", "pre-commit", "pre-merge"]
            }
          },
          "predicate": { "type": "string" },
          "metric": { "type": "string" },
          "threshold": { "type": "number" },
          "short": { "type": "string" },
          "long": { "type": "string" },
          "audio_preamble_vi": { "type": "string" },
          "audio_preamble_en": { "type": "string" },
          "rationalizations": {
            "type": "array",
            "description": "Common excuses an agent uses to skip this rule, paired with the counter-argument.",
            "items": {
              "type": "object",
              "required": ["lie", "truth"],
              "properties": {
                "lie": { "type": "string", "description": "The excuse the agent tells itself." },
                "truth": { "type": "string", "description": "Why the excuse is wrong." }
              }
            }
          },
          "red_flags": {
            "type": "array",
            "description": "Observable anti-patterns that indicate this rule is being violated. Predicate-friendly.",
            "items": { "type": "string" }
          }
        }
      }
    },
    "gates": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "verification_graph": {
      "type": "object",
      "properties": {
        "nodes": {
          "oneOf": [
            { "type": "array", "items": { "type": "string" } },
            {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": { "type": "string" },
                  "evidence": {
                    "type": "array",
                    "description": "Required evidence artifacts for this node (e.g. exit_code, tail:20, regression_test).",
                    "items": { "type": "string" }
                  }
                }
              }
            }
          ]
        },
        "edges": {
          "type": "array",
          "items": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 }
        }
      }
    },
    "verification_commands": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "telemetry": {
      "type": "object",
      "properties": {
        "endpoint": { "type": "string", "format": "uri" },
        "opt_in": { "type": "boolean" },
        "local_log_path": { "type": "string" }
      }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "skills": {
      "type": "array",
      "description": "Optional workflow skills referenced by rules. Loaded from rules/skills/<id>.toml at build time.",
      "items": {
        "type": "object",
        "required": ["id", "title", "phase", "when", "process"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "phase": { "type": "string", "enum": ["define", "plan", "build", "verify", "review", "ship", "meta"] },
          "source": { "type": "string", "format": "uri", "description": "Upstream URL when adapted from external work." },
          "source_license": { "type": "string" },
          "when": { "type": "array", "items": { "type": "string" } },
          "process": { "type": "array", "items": { "type": "string" } },
          "rationalizations": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["lie", "truth"],
              "properties": {
                "lie": { "type": "string" },
                "truth": { "type": "string" }
              }
            }
          },
          "red_flags": { "type": "array", "items": { "type": "string" } },
          "verification": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "personas": {
      "type": "array",
      "description": "Reusable agent personas (code-reviewer, security-auditor, etc.).",
      "items": {
        "type": "object",
        "required": ["id", "role", "summary"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "role": { "type": "string" },
          "summary": { "type": "string" },
          "axes": { "type": "array", "items": { "type": "string" } },
          "output_format": { "type": "string" }
        }
      }
    },
    "commands": {
      "type": "array",
      "description": "Slash command entry points (rendered to platforms that support them).",
      "items": {
        "type": "object",
        "required": ["id", "trigger", "summary"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9:-]+$" },
          "trigger": { "type": "string", "description": "User-typed slash command, e.g. /cg:spec" },
          "summary": { "type": "string" },
          "invokes": { "type": "array", "items": { "type": "string" }, "description": "Skill or persona IDs invoked." },
          "prompt": { "type": "string" }
        }
      }
    }
  }
}
