{
  "name": "@memoryai.dev/coding-guard",
  "version": "2.0.1",
  "description": "Universal coding-agent guardrails: 4 core principles + anti-sloppy enforcement, installs into 11 IDE/CLI in one command. Family of @memoryai.dev/*-guard.",
  "keywords": [
    "ai",
    "coding-agent",
    "claude-code",
    "cursor",
    "copilot",
    "aider",
    "codex",
    "windsurf",
    "cline",
    "rules",
    "guardrails",
    "anti-sloppy",
    "memoryai"
  ],
  "homepage": "https://memoryai.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CH270035/memoryai-coding-guard.git"
  },
  "bugs": {
    "url": "https://github.com/CH270035/memoryai-coding-guard/issues"
  },
  "author": {
    "name": "MemoryAI",
    "url": "https://memoryai.dev"
  },
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "coding-guard": "./bin/cli.js",
    "cg": "./bin/cli.js"
  },
  "main": "./lib/index.js",
  "files": [
    "bin/",
    "lib/",
    "rules/",
    "platforms/",
    "runtimes/",
    "scripts/",
    "telemetry/",
    "eval/",
    "docs/",
    "references/",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "node lib/builder.js",
    "validate": "node lib/validator.js",
    "verify": "node lib/signer.js verify",
    "sign": "node lib/signer.js sign",
    "test": "node --test eval/runner.js eval/builder-snapshot.test.js",
    "prepublishOnly": "npm run validate && npm run build && npm run verify"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "commander": "^12.1.0",
    "kleur": "^4.1.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
